import os
import json
import agent

# Extract password from existing lam.conf before removing file
file_path = "lam-config/lam.conf"
config_file = "lam-config/config.cfg"

if os.path.isfile(file_path):
    try:
        with open(file_path, 'r') as f:
            config_data = json.load(f)
            ldap_password = config_data.get("Passwd", "")
            if ldap_password:
                agent.set_env("LDAP_PASSWORD", ldap_password)
    except (json.JSONDecodeError, IOError):
        pass  # File may not be valid JSON, proceed without password

# Extract password from existing config.cfg before removing file
if os.path.isfile(config_file):
    try:
        with open(config_file, 'r') as f:
            config_data = json.load(f)
            config_password = config_data.get("password", "")
            if config_password:
                agent.set_env("CONFIG_PASSWORD", config_password)
    except (json.JSONDecodeError, IOError):
        pass  # File may not be valid JSON, proceed without password
